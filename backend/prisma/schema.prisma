generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ChallengeDifficulty {
  EASY
  MEDIUM
  HARD
}

enum RequestStatus {
  PENDING_CHALLENGER
  PENDING_RECIPIENT
  MATCHED
  FAILED
  CANCELLED
}

enum MessageFormat {
  TEXT
  MARKDOWN
  CODE
}

model User {
  id               String             @id @default(cuid())
  email            String             @unique
  name             String
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  profile          Profile?
  outgoingRequests InterestRequest[]  @relation("OutgoingRequests")
  incomingRequests InterestRequest[]  @relation("IncomingRequests")
  attempts         ChallengeAttempt[]
  matchesAsA       Match[]            @relation("MatchUserA")
  matchesAsB       Match[]            @relation("MatchUserB")
  chatMessages     ChatMessage[]
}

model Profile {
  id                     String              @id @default(cuid())
  userId                 String              @unique
  occupation             String?
  age                    Int?
  hobbies                String[]
  editorChoice           String?
  languageChoice         String?
  githubUsername         String?
  vibeBadge              String?
  favoriteFramework      String?
  favoriteOS             String?
  favoriteDataStructure  String?
  favoriteAlgorithm      String?
  challengeLevel         ChallengeDifficulty @default(EASY)
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  user                   User                @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Challenge {
  id            String              @id @default(cuid())
  slug          String              @unique
  title         String
  difficulty    ChallengeDifficulty
  description   String
  starterCode   Json?
  testCases     Json
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  requests      InterestRequest[]

  @@index([difficulty])
}

model InterestRequest {
  id          String             @id @default(cuid())
  challengerId String
  targetId    String
  challengeId String
  status      RequestStatus      @default(PENDING_CHALLENGER)
  createdAt   DateTime           @default(now())
  requestedAt DateTime?
  matchedAt   DateTime?
  challenger  User               @relation("OutgoingRequests", fields: [challengerId], references: [id], onDelete: Cascade)
  target      User               @relation("IncomingRequests", fields: [targetId], references: [id], onDelete: Cascade)
  challenge   Challenge          @relation(fields: [challengeId], references: [id], onDelete: Restrict)
  attempts    ChallengeAttempt[]
  match       Match?

  @@index([challengerId, status])
  @@index([targetId, status])
}

model ChallengeAttempt {
  id            String          @id @default(cuid())
  requestId     String
  userId        String
  passed        Boolean
  submittedCode String?
  createdAt     DateTime        @default(now())
  request       InterestRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([requestId, userId])
  @@index([userId, createdAt])
}

model Match {
  id        String   @id @default(cuid())
  requestId String   @unique
  userAId   String
  userBId   String
  createdAt DateTime @default(now())
  request   InterestRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  userA     User     @relation("MatchUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB     User     @relation("MatchUserB", fields: [userBId], references: [id], onDelete: Cascade)
  room      ChatRoom?

  @@index([userAId])
  @@index([userBId])
}

model ChatRoom {
  id        String        @id @default(cuid())
  matchId   String        @unique
  createdAt DateTime      @default(now())
  match     Match         @relation(fields: [matchId], references: [id], onDelete: Cascade)
  messages  ChatMessage[]
}

model ChatMessage {
  id        String        @id @default(cuid())
  roomId    String
  senderId  String
  content   String
  format    MessageFormat @default(MARKDOWN)
  createdAt DateTime      @default(now())
  room      ChatRoom      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  sender    User          @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([roomId, createdAt])
}
