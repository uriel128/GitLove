NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:3000
# SQLite URL used by Prisma
# This creates/uses backend/prisma/dev.db
DATABASE_URL=file:./dev.db

# Firebase Admin auth verification config
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Keep escaped newlines (\\n) if you paste from a single-line secret
FIREBASE_PRIVATE_KEY=
CHAT_NAMESPACE=/chat
